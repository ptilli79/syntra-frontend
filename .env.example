# Public site URL — used by metadataBase, sitemap, robots, OG tags.
# Local dev: leave unset (defaults to http://localhost:3000)
# Vercel:    set to your production domain, e.g. https://syntra.build
NEXT_PUBLIC_SITE_URL=

# Public contact email shown in the contact modal and privacy page.
# Leave unset to use the in-code default.
NEXT_PUBLIC_CONTACT_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar Integration (Booking System)
# ─────────────────────────────────────────────────────────────────────────────
# Service account email from the GCP service account JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the service account JSON (include full PEM with \n for newlines)
GOOGLE_PRIVATE_KEY=

# Calendar ID to create events on (usually the calendar owner's email)
GOOGLE_CALENDAR_ID=hello@syntra.build

# ─────────────────────────────────────────────────────────────────────────────
# Email Configuration (Gmail SMTP)
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: For Gmail, you must use an App Password (not your regular password)
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a new App Password for "Mail" and use it below

# Gmail account used to send emails
SMTP_USER=hello@syntra.build

# Gmail App Password (16-character code from Google)
SMTP_PASSWORD=

# Destination email for contact form submissions
CONTACT_EMAIL=hello@syntra.build

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting (Upstash Redis) — https://upstash.com
# ─────────────────────────────────────────────────────────────────────────────
# Create a free Upstash Redis database and paste its REST URL + token here.
# When these are UNSET the app falls back to a per-instance in-memory limiter,
# which is fine for local dev but NOT reliable on serverless (Vercel). Set both
# in production so limits are enforced globally across all instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin
# ─────────────────────────────────────────────────────────────────────────────
# Register a reCAPTCHA v3 (score-based) site for your domain(s). Add
# "localhost" as an allowed domain for local testing.
# When these are UNSET, bot verification is skipped (app still works). Set both
# in production to protect the contact + booking forms.
#
# Public site key — safe to expose to the browser.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Secret key — server only, NEVER expose.
RECAPTCHA_SECRET_KEY=
# Optional: minimum score (0.0–1.0) to accept. Defaults to 0.5.
RECAPTCHA_SCORE_THRESHOLD=0.5

