# Public site URL — used by metadataBase, sitemap, robots, OG tags.
# Local dev: leave unset (defaults to http://localhost:3000)
# Vercel:    set to your production domain, e.g. https://syntra.build
NEXT_PUBLIC_SITE_URL=

# Public contact email shown in the contact modal and privacy page.
# Leave unset to use the in-code default.
NEXT_PUBLIC_CONTACT_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar Integration (Booking System)
# ─────────────────────────────────────────────────────────────────────────────
# Service account email from the GCP service account JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the service account JSON (include full PEM with \n for newlines)
GOOGLE_PRIVATE_KEY=

# Calendar ID to create events on (usually the calendar owner's email)
GOOGLE_CALENDAR_ID=hello@syntra.build

# ─────────────────────────────────────────────────────────────────────────────
# Email Configuration (Gmail SMTP)
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: For Gmail, you must use an App Password (not your regular password)
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a new App Password for "Mail" and use it below

# Gmail account used to send emails
SMTP_USER=hello@syntra.build

# Gmail App Password (16-character code from Google)
SMTP_PASSWORD=

# Destination email for contact form submissions
CONTACT_EMAIL=hello@syntra.build
