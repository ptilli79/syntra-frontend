# Public site URL — used by metadataBase, sitemap, robots, OG tags.
# Local dev: leave unset (defaults to http://localhost:3000)
# Vercel:    set to your production domain, e.g. https://syntra.build
NEXT_PUBLIC_SITE_URL=

# Public contact email shown in the contact modal and privacy page.
# Leave unset to use the in-code default.
NEXT_PUBLIC_CONTACT_EMAIL=
